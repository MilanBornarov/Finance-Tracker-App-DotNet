@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="container mt-5" style="max-width: 420px">
    <div class="text-center mb-4">
        <span style="font-size:3rem">💰</span>
        <h2 class="fw-bold mt-2">@ViewData["Title"]</h2>
        
        @{
            if (User.Identity?.IsAuthenticated ?? false)
            {
                <p class="text-muted">Are you sure you want to sign out?</p>
            }
            else
            {
                <p class="text-success">You have successfully logged out.</p>
            }
        }
    </div>

    <div class="card shadow-sm border-0 p-4 text-center">
        @{
            if (User.Identity?.IsAuthenticated ?? false)
            {
                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                    <button type="submit" class="btn btn-danger w-100 fw-semibold">Confirm Logout</button>
                </form>
                <div class="mt-3">
                    <a href="/" class="text-decoration-none small fw-semibold">Cancel and Go Back</a>
                </div>
            }
            else
            {
                <div class="py-3">
                    <p class="mb-4">Thanks for using FinanceTracker!</p>
                    <a asp-page="./Login" class="btn btn-primary w-100 fw-semibold">Sign In Again</a>
                </div>
            }
        }
    </div>
</div>