@model FinanceTrackerApp.ViewModels.TransactionIndexViewModel
@using FinanceTrackerApp.Helpers
@{
    ViewData["Title"] = "My Transactions";
}

<div class="container mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4 border-0">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">💳 My Transactions</h2>
        <a asp-action="Create" class="btn btn-primary rounded-3 px-4 shadow-sm d-flex align-items-center gap-2">
            <span class="fw-bold">+</span> Add Transaction
        </a>
    </div>

    @* Filter *@
    <div class="card mb-4 shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 py-3"
             style="cursor: pointer;"
             data-bs-toggle="collapse"
             data-bs-target="#filterPanel"
             role="button">
            <div class="d-flex justify-content-between align-items-center">
                <div class="fw-semibold text-primary">
                    🔍 Search & Filter
                    @if (Model.Filter.IsActive)
                    {
                        <span class="badge rounded-pill bg-primary ms-2">Active</span>
                    }
                </div>
                <div>
                    @if (Model.Filter.IsActive)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-link text-danger text-decoration-none me-2 fw-bold" onclick="event.stopPropagation();">✕ Clear All</a>
                    }
                    <span class="text-muted small">▼</span>
                </div>
            </div>
        </div>

        <div id="filterPanel" class="collapse @(Model.Filter.IsActive ? "show" : "")">
            <div class="card-body bg-light border-top">
                <form method="get" asp-action="Index">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted">Keywords</label>
                            <input type="text" name="search" value="@Model.Filter.Search" class="form-control rounded-3 border-0 shadow-sm" placeholder="Search description..." />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-semibold small text-muted">Type</label>
                            <select name="type" class="form-select rounded-3 border-0 shadow-sm">
                                <option value="">All Types</option>
                                <option value="Income" selected="@(Model.Filter.Type == "Income")">Income</option>
                                <option value="Expense" selected="@(Model.Filter.Type == "Expense")">Expense</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold small text-muted">Category</label>
                            <select name="category" class="form-select rounded-3 border-0 shadow-sm">
                                <option value="">All Categories</option>
                                @foreach (var cat in Model.AvailableCategories)
                                {
                                    <option value="@cat" selected="@(Model.Filter.Category == cat)">@cat</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold small text-muted">Date Range</label>
                            <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                <input type="date" name="dateFrom" value="@Model.Filter.DateFrom?.ToString("yyyy-MM-dd")" class="form-control border-0" />
                                <input type="date" name="dateTo" value="@Model.Filter.DateTo?.ToString("yyyy-MM-dd")" class="form-control border-0" />
                            </div>
                        </div>

                        <div class="col-12 d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary rounded-3 px-4">Apply Filters</button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-3 px-4">Reset</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* Table *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0 custom-table">
                <thead>
                    <tr>
                        <th class="ps-4 py-3 border-0">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["DateSort"]">DATE <small>↕</small></a>
                        </th>
                        <th class="py-3 border-0">DESCRIPTION</th>
                        <th class="py-3 border-0">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["CategorySort"]">CATEGORY <small>↕</small></a>
                        </th>
                        <th class="py-3 border-0">TYPE</th>
                        <th class="py-3 border-0 text-end">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["AmountSort"]">AMOUNT <small>↕</small></a>
                        </th>
                        <th class="py-3 border-0 text-center pe-4">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Transactions.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">No transactions found.</td>
                        </tr>
                    }
                    @foreach (var t in Model.Transactions)
                    {
                        <tr>
                            <td class="ps-4 text-muted small">@t.Date.ToString("dd MMM yyyy")</td>
                            <td class="fw-bold text-dark">@t.Description</td>
                            <td>
                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2">@t.Category</span>
                            </td>
                            <td>
                                <span class="badge rounded-pill px-3 py-2
                                    @(t.Type == "Income" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                    @t.Type.ToUpper()
                                </span>
                            </td>
                            <td class="text-end fw-bold @(t.Type == "Income" ? "text-success" : "text-danger")">
                                @(t.Type == "Income" ? "+" : "-")@t.Amount.ToString("N0") ден
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group rounded-3 overflow-hidden border shadow-sm action-group">
                                    <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-sm btn-white border-0">📄</a>
                                    <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-white border-start border-end">✏️</a>
                                    <a asp-action="Delete" asp-route-id="@t.Id" class="btn btn-sm btn-white border-0">🗑️</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <nav class="d-flex flex-column align-items-center">
        <ul class="pagination pagination-sm mb-2">
            <li class="page-item @(!Model.Transactions.HasPreviousPage ? "disabled" : "")">
                <a class="page-link border shadow-none px-3" asp-action="Index" asp-route-page="@(Model.Transactions.PageIndex - 1)" asp-route-sortOrder="@Model.CurrentSort">Previous</a>
            </li>
            @for (int i = 1; i <= Model.Transactions.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Transactions.PageIndex ? "active" : "")">
                    <a class="page-link border shadow-none px-3" asp-action="Index" asp-route-page="@i" asp-route-sortOrder="@Model.CurrentSort">@i</a>
                </li>
            }
            <li class="page-item @(!Model.Transactions.HasNextPage ? "disabled" : "")">
                <a class="page-link border shadow-none px-3" asp-action="Index" asp-route-page="@(Model.Transactions.PageIndex + 1)" asp-route-sortOrder="@Model.CurrentSort">Next</a>
            </li>
        </ul>
        <p class="text-muted" style="font-size: 0.75rem;">Page @Model.Transactions.PageIndex of @Model.Transactions.TotalPages</p>
    </nav>
</div>

<style>

    .custom-table thead th {
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.05rem;
        color: #6c757d;
        background-color: #fcfcfc;
    }
    
    .custom-table thead a {
        color: #6c757d;
        text-decoration: none;
        display: block;
        width: 100%;
    }

    .custom-table tbody tr {
        transition: transform 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
        cursor: default;
    }

        .custom-table tbody tr:hover {
            background-color: #f8f9fa !important;
            transform: translateY(-1px);
            box-shadow: inset 4px 0 0 #0d6efd, 0 4px 12px rgba(0,0,0,0.05);
            z-index: 5;
            position: relative;
        }

    .action-group .btn:hover {
        background-color: #eee;
    }

    .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
    
    .card:hover {
        transform: translateY(-2px);
        transition: transform 0.3s ease;
    }
</style>